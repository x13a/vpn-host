{
    admin off
}

https://{$DOMAIN} {
    route {$PANEL_PATH}* {
        reverse_proxy http://3x-ui:2053
    }
    route {$SUB_PATH}* {
        reverse_proxy http://3x-ui:2096
    }
    route {$XHTTP_PATH}* {
        reverse_proxy http://3x-ui:8000
    }
    route {$XHTTP_WARP_PATH}* {
        reverse_proxy http://3x-ui:8001
    }
    root * /www
    file_server
}
